# ============================================================
# Autonomous Multi-Agent Desktop OS — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# ── LLM Provider (Ollama — local or remote) ──────────────────
# Used ONLY for planning/task decomposition. All execution is local.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_API_KEY=

# ── Browser ──────────────────────────────────────────────────
# Leave empty to use system default Brave/Chrome
BROWSER_EXECUTABLE_PATH=

# ── Workspace ────────────────────────────────────────────────
# Directory where agents save output files (Excel, text, etc.)
WORKSPACE_ROOT=./workspace

# ── Safety ───────────────────────────────────────────────────
# Human-in-the-loop approval for sensitive actions (true/false)
REQUIRE_APPROVAL=true

# Fail-safe: move mouse to screen corner to abort (true/false)
FAILSAFE_ENABLED=true

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
